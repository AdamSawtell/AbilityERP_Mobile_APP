# Copy to web/.env.local for local development

# Public app URL (used for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# EC2 API host (no trailing /api — routes include /api/...)
API_BASE_URL=http://localhost:3001

# Microsoft Entra ID (optional until SSO app registration is ready)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:3000/api/auth/ms-callback
