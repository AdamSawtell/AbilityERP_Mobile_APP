# AbilityERP Worker API — environment variables
# Copy to /opt/ability-erp-pwa/.env on EC2 (never commit real values)

PORT=3001
NODE_ENV=production
APP_VERSION=0.1.0

# PostgreSQL (same host as iDempiere — typically localhost:5432 on EC2)
DATABASE_URL=postgresql://adempiere:CHANGE_ME@127.0.0.1:5432/idempiere

# JWT signing secret (generate a long random string)
JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET

# Comma-separated Amplify / app URLs allowed to call this API
CORS_ORIGIN=https://your-amplify-app.amplifyapp.com,http://localhost:3000
